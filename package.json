{
  "name": "offline-bible-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "data:fetch": "bash scripts/etl/01-fetch-sources.sh",
    "data:parse": "tsx scripts/etl/02-parse-cuv.ts && tsx scripts/etl/03-parse-net.ts && tsx scripts/etl/04-parse-gnt.ts && tsx scripts/etl/05-parse-wlc.ts",
    "data:merge": "tsx scripts/etl/06-merge.ts && tsx scripts/etl/07-index.ts",
    "data:build": "npm run data:fetch && npm run data:parse && npm run data:merge"
  },
  "dependencies": {
    "workbox-core": "^7.1.0",
    "workbox-expiration": "^7.1.0",
    "workbox-precaching": "^7.1.0",
    "workbox-routing": "^7.1.0",
    "workbox-strategies": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5"
  }
}
